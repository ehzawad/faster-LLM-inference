# Copy to .env and edit. Never commit the real .env.

# Your domain. A DNS A-record for it must point to this host BEFORE `docker compose up`
# (Caddy provisions a TLS cert on first boot). Use a real domain, not a bare IP.
DOMAIN=assistant.example.gov.bd

# Shared secret between Open WebUI and llama-server. The browser never sees it.
# Generate a strong one:  openssl rand -hex 32
INFERENCE_API_KEY=replace-with-openssl-rand-hex-32

# Persistent Open WebUI JWT/encryption secret. Generate a different strong value:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=replace-with-different-openssl-rand-hex-32

# Branding shown in the chat panel header
WEBUI_NAME=বাংলাদেশ NID/EC সহায়ক

# Non-dismissible bilingual safety banner: PII warning + "verify on official source".
# Required for a citizen-facing gov bot (recall-sensitive: do not trust it for live fees/deadlines).
WEBUI_BANNERS=[{"id":"nid-disclaimer","type":"warning","title":"সতর্কতা / Notice","content":"এটি সাধারণ সহায়তা মাত্র, সরকারি সিদ্ধান্ত নয়। ফি, সময়সীমা ও নথির জন্য নির্বাচন কমিশনের অফিসিয়াল সূত্র যাচাই করুন (services.nidw.gov.bd / হেল্পলাইন ১০৫)। NID নম্বর, OTP বা সংবেদনশীল তথ্য শেয়ার করবেন না।","dismissible":false,"timestamp":1}]
